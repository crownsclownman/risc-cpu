#include "core/execute.h"
#include "core/execute/internal.h"
#include "core/bus.h"
#include "core/isa.h"

#include <stdio.h>
#include <stdint.h>

static inline int32_t sign_ext16(uint32_t v) {
    return (int32_t)(int16_t)(uint16_t)v;
}

static inline uint32_t branch_target(cpu_t *arch, int32_t imm) {
    return (arch->pc + 4) + (imm << 2);
}

static inline uint32_t jump_target(cpu_t *arch, uint32_t target) {
    uint32_t base = (arch->pc + 4) & 0xF0000000u;
    return base | ((target & 0x03FFFFFFu) << 2);
}

static inline void reg_write(cpu_t *arch, uint8_t reg, uint32_t value) {
    if (reg != 0)
        arch->registers[reg] = value;
}

void execute(cpu_t *arch, decoded_instruction_t *d) {
    uint32_t rs   = arch->registers[d->rs];
    uint32_t rt   = arch->registers[d->rt];
    int32_t  srs  = (int32_t)rs;
    int32_t  srt  = (int32_t)rt;
    int32_t  simm = sign_ext16(d->imm);
    uint32_t ea;

    uint32_t next_pc = arch->pc + 4;

    switch (d->opcode) {

    case OP_SPECIAL:
        switch (d->funct) {

        case FUNCT_SLL:
            reg_write(arch, d->rd, rt << d->shamt);
            break;

        case FUNCT_SRL:
            reg_write(arch, d->rd, rt >> d->shamt);
            break;

        case FUNCT_SRA:
            reg_write(arch, d->rd, (uint32_t)((int32_t)rt >> d->shamt));
            break;

        case FUNCT_SLLV:
            reg_write(arch, d->rd, rt << (rs & 0x1F));
            break;

        case FUNCT_SRLV:
            reg_write(arch, d->rd, rt >> (rs & 0x1F));
            break;

        case FUNCT_SRAV:
            reg_write(arch, d->rd, (uint32_t)((int32_t)rt >> (rs & 0x1F)));
            break;

        case FUNCT_JR:
            next_pc = rs;
            break;

        case FUNCT_JALR:
            reg_write(arch, d->rd, arch->pc + 4);
            next_pc = rs;
            break;

        case FUNCT_SYSCALL:
            /*
             * Сохраняем адрес следующей инструкции в EPC,
             * затем передаём управление обработчику (TODO: вектор).
             * Пока: halt для отладки на ранних этапах.
             */
            arch->epc   = arch->pc + 4;
            arch->cause = CAUSE_SYSCALL;
            arch->sr   |= SR_KM;
            arch->sr   &= ~SR_IE;
            next_pc     = EXCEPTION_VECTOR;
            break;

        case FUNCT_ERET:
            next_pc   = arch->epc;
            arch->sr &= ~SR_KM;
            break;

        case FUNCT_MUL:
            reg_write(arch, d->rd, (uint32_t)((int64_t)srs * srt));
            break;

        case FUNCT_MULH:
            reg_write(arch, d->rd,
                      (uint32_t)(((int64_t)srs * (int64_t)srt) >> 32));
            break;

        case FUNCT_DIV:
            if (rt == 0) {
                arch->cause = CAUSE_DIV_ZERO;
                arch->epc   = arch->pc;
                arch->sr   |= SR_KM;
                next_pc     = EXCEPTION_VECTOR;
                break;
            }
            reg_write(arch, d->rd, (uint32_t)(srs / srt));
            break;

        case FUNCT_DIVU:
            if (rt == 0) {
                arch->cause = CAUSE_DIV_ZERO;
                arch->epc   = arch->pc;
                arch->sr   |= SR_KM;
                next_pc     = EXCEPTION_VECTOR;
                break;
            }
            reg_write(arch, d->rd, rs / rt);
            break;

        case FUNCT_REM:
            if (rt == 0) {
                arch->cause = CAUSE_DIV_ZERO;
                arch->epc   = arch->pc;
                arch->sr   |= SR_KM;
                next_pc     = EXCEPTION_VECTOR;
                break;
            }
            reg_write(arch, d->rd, (uint32_t)(srs % srt));
            break;

        case FUNCT_REMU:
            if (rt == 0) {
                arch->cause = CAUSE_DIV_ZERO;
                arch->epc   = arch->pc;
                arch->sr   |= SR_KM;
                next_pc     = EXCEPTION_VECTOR;
                break;
            }
            reg_write(arch, d->rd, rs % rt);
            break;

        case FUNCT_ADD:
            reg_write(arch, d->rd, rs + rt);
            break;

        case FUNCT_SUB:
            reg_write(arch, d->rd, rs - rt);
            break;

        case FUNCT_AND:
            reg_write(arch, d->rd, rs & rt);
            break;

        case FUNCT_OR:
            reg_write(arch, d->rd, rs | rt);
            break;

        case FUNCT_XOR:
            reg_write(arch, d->rd, rs ^ rt);
            break;

        case FUNCT_NOR:
            reg_write(arch, d->rd, ~(rs | rt));
            break;

        case FUNCT_SLT:
            reg_write(arch, d->rd, srs < srt ? 1u : 0u);
            break;

        case FUNCT_SLTU:
            reg_write(arch, d->rd, rs < rt ? 1u : 0u);
            break;

        case FUNCT_TLBWR:   tlb_write_random(arch);          break;
        case FUNCT_TLBR:    tlb_read(arch);                  break;
        case FUNCT_TLBP:    tlb_probe(arch);                  break;
        case FUNCT_TLBINV:  tlb_invalidate(arch, rs);         break;

        case FUNCT_FENCE:
            /* В однопоточном эмуляторе барьер памяти — NOP.
             * Важна семантика, не реализация. */
            break;

        case FUNCT_WFI:
            arch->waiting = 1;
            break;

        case FUNCT_NOP:
            break;

        case FUNCT_HALT:
            arch->is_halted = 1;
            break;

        default:
            fprintf(stderr,
                    "execute: неизвестный funct=0x%02X на PC=0x%08X\n",
                    d->funct, arch->pc);
            arch->cause = CAUSE_ILL_INSTR;
            arch->epc   = arch->pc;
            arch->sr   |= SR_KM;
            next_pc     = EXCEPTION_VECTOR;
            break;
        }
        break; /* end OP_SPECIAL */

    case OP_ADDI:
        reg_write(arch, d->rt, (uint32_t)(srs + simm));
        break;

    case OP_SLTI:
        reg_write(arch, d->rt, srs < simm ? 1u : 0u);
        break;

    case OP_SLTIU:
        reg_write(arch, d->rt, rs < (uint32_t)simm ? 1u : 0u);
        break;

    case OP_ANDI:
        reg_write(arch, d->rt, rs & (uint32_t)d->imm);
        break;

    case OP_ORI:
        reg_write(arch, d->rt, rs | (uint32_t)d->imm);
        break;

    case OP_XORI:
        reg_write(arch, d->rt, rs ^ (uint32_t)d->imm);
        break;

    /*case OP_LUI:
        reg_write(arch, d->rt, (uint32_t)d->imm << 16);
        break;*/

    case OP_BEQ:
        if (rs == rt)               next_pc = branch_target(arch, simm);
        break;

    case OP_BNE:
        if (rs != rt)               next_pc = branch_target(arch, simm);
        break;

    case OP_BLT:
        if (srs < srt)              next_pc = branch_target(arch, simm);
        break;

    case OP_BGE:
        if (srs >= srt)             next_pc = branch_target(arch, simm);
        break;

    case OP_BLTU:
        if (rs < rt)                next_pc = branch_target(arch, simm);
        break;

    case OP_BGEU:
        if (rs >= rt)               next_pc = branch_target(arch, simm);
        break;

    case OP_LB:
        ea = (uint32_t)(srs + simm);
        reg_write(arch, d->rt, (uint32_t)(int32_t)(int8_t)cpu_read8(arch, ea));
        break;

    case OP_LH:
        ea = (uint32_t)(srs + simm);
        reg_write(arch, d->rt, (uint32_t)(int32_t)(int16_t)cpu_read16(arch, ea));
        break;

    case OP_LW:
        ea = (uint32_t)(srs + simm);
        reg_write(arch, d->rt, cpu_read32(arch, ea));
        break;

    case OP_LBU:
        ea = (uint32_t)(srs + simm);
        reg_write(arch, d->rt, (uint32_t)cpu_read8(arch, ea));
        break;

    case OP_LHU:
        ea = (uint32_t)(srs + simm);
        reg_write(arch, d->rt, (uint32_t)cpu_read16(arch, ea));
        break;

    case OP_SB:
        ea = (uint32_t)(srs + simm);
        cpu_write8(arch, ea, (uint8_t)(rt & 0xFF));
        break;

    case OP_SH:
        ea = (uint32_t)(srs + simm);
        cpu_write16(arch, ea, (uint16_t)(rt & 0xFFFF));
        break;

    case OP_SW:
        ea = (uint32_t)(srs + simm);
        cpu_write32(arch, ea, rt);
        break;

    case OP_LL:
        ea = (uint32_t)(srs + simm);
        arch->lladdr  = ea;
        arch->ll_valid = 1;
        reg_write(arch, d->rt, cpu_read32(arch, ea));
        break;

    case OP_SC:
        ea = (uint32_t)(srs + simm);
        if (arch->ll_valid && arch->lladdr == ea) {
            cpu_write32(arch, ea, rt);
            reg_write(arch, d->rt, 1u);
        } else {
            reg_write(arch, d->rt, 0u);
        }
        arch->ll_valid = 0;
        break;

    case OP_SYSTEM:
        /*
         * Формат: OPCODE[31:26]=0x10, RS[25:21]=sub-op
         *   sub=0x00 -> MFC0  RT(dst) = CSR[RD]
         *   sub=0x04 -> MTC0  CSR[RD] = RS
         */
        switch (d->rs) {
        case 0x00: /* MFC0 */
            reg_write(arch, d->rt, csr_read(arch, d->rd));
            break;
        case 0x04: /* MTC0 */
            csr_write(arch, d->rd, rt);
            break;
        default:
            fprintf(stderr,
                    "execute: неизвестный OP_SYSTEM sub=0x%02X на PC=0x%08X\n",
                    d->rs, arch->pc);
            break;
        }
        break;

    case OP_J:
        next_pc = jump_target(arch, d->target);
        break;

    case OP_JAL:
        reg_write(arch, 31, arch->pc + 4);   /* R31 = link register */
        next_pc = jump_target(arch, d->target);
        break;

    default:
        fprintf(stderr,
                "execute: неизвестный opcode=0x%02X на PC=0x%08X\n",
                d->opcode, arch->pc);
        arch->cause = CAUSE_ILL_INSTR;
        arch->epc   = arch->pc;
        arch->sr   |= SR_KM;
        next_pc     = EXCEPTION_VECTOR;
        break;
    }

    arch->registers[0] = 0;

    if (!arch->is_halted)
        arch->pc = next_pc;
}
